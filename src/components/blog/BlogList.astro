---
import type { CollectionEntry } from "astro:content";
import BlogSummaryCard from "./BlogSummaryCard.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

<div class="mx-auto w-full max-w-5xl py-4 sm:py-6 select-none">
  
  {/* ── HEADER SECTION ── */}
  <header class="mb-12 max-w-2xl">
    <span class="inline-block px-2.5 py-0.5 rounded border-[1.5px] border-black bg-[#ffe977] text-[9px] font-black uppercase tracking-[0.18em] shadow-[2px_2px_0_0_#000]" style="font-family: 'Space Mono', monospace;">
      The Lab
    </span>
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-black uppercase tracking-tight text-[#111827] mt-4 mb-3" style="font-family: 'Outfit', sans-serif;">
      Product Experiments
    </h1>
    <p class="text-sm sm:text-base leading-relaxed text-gray-500" style="font-family: system-ui, -apple-system, sans-serif;">
      A curated index of strategic teardowns, product requirements, and interactive prototypes built to solve user and partner experience friction.
    </p>
  </header>

  {/* ── DOSSIER INDEX (LEDGER LIST) ── */}
  <div class="border-t-[1.5px] border-black mt-8 flex flex-col divide-y divide-black/15">
    {posts.map((post, index) => {
      const postIndex = posts.length - index;
      return (
        <div class="py-1 first:pt-2 last:pb-2">
          <BlogSummaryCard post={post} index={postIndex} />
        </div>
      );
    })}
  </div>

</div>
