---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  index: number;
  href?: string;
}

const { post, index, href } = Astro.props;

// Format date
const publishedOn = new Intl.DateTimeFormat("en-US", {
  month: "short",
  year: "numeric",
}).format(post.data.pubDate);

// Read time calculation
const words = (post.body ?? "").split(/\s+/).length;
const wpm = 200;
const timeToRead = Math.ceil(words / wpm);
const readTime = `${timeToRead} min read`;

const slug = post.id.split("/").pop() ?? post.id;

// Unique hover styles for each case study matching their company themes
const hoverClasses: Record<string, string> = {
  "proofit-prd": "hover:bg-[#f0f7ff] hover:border-black hover:shadow-[4px_4px_0_0_#111827]",
  "urban-company-teardown": "hover:bg-[#fffbeb] hover:border-black hover:shadow-[4px_4px_0_0_#111827]",
};

const hoverStyle = hoverClasses[slug] || "hover:bg-gray-50 hover:border-black hover:shadow-[4px_4px_0_0_#111827]";
---

<a
  href={href ?? `/blog/${post.id}/`}
  class={`block w-full border-[1.5px] border-transparent bg-transparent rounded-xl p-4 sm:p-5 md:p-6 transition-all duration-200 group text-left ${hoverStyle}`}
>
  <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between md:gap-8">
    
    {/* Left Column: Numbering & Title & Desc */}
    <div class="flex items-start gap-4 md:gap-6 flex-1 min-w-0">
      
      {/* Index Number */}
      <span 
        class="text-sm font-black tracking-tight text-gray-300 group-hover:text-[#111827] transition-colors leading-none pt-1" 
        style="font-family: 'Space Mono', monospace;"
      >
        {index.toString().padStart(2, "0")}.
      </span>
      
      {/* Article Content */}
      <div class="space-y-1 min-w-0">
        <h3 
          class="text-lg sm:text-xl font-bold tracking-tight text-gray-900 group-hover:text-black transition-colors"
          style="font-family: 'Outfit', sans-serif;"
        >
          {post.data.title}
        </h3>
        <p class="text-xs sm:text-sm text-gray-500 group-hover:text-gray-700 transition-colors leading-relaxed line-clamp-2">
          {post.data.description}
        </p>
      </div>
      
    </div>

    {/* Right Column: Metadata & Badges */}
    <div class="flex flex-wrap items-center justify-between gap-4 md:flex-nowrap md:justify-end md:gap-6 flex-shrink-0 pt-2 md:pt-0 border-t border-black/5 md:border-t-0">
      
      {/* Date & Reading Time */}
      <div class="flex items-center gap-3 text-[11px] font-bold text-gray-400 group-hover:text-gray-500 transition-colors" style="font-family: 'Space Mono', monospace;">
        <span>{publishedOn}</span>
        <span class="opacity-30">•</span>
        <span>{readTime}</span>
      </div>

      {/* Primary Category Tags */}
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex items-center gap-1.5">
          {post.data.tags.slice(0, 2).map((tag) => (
            <span class="text-[9px] font-extrabold uppercase tracking-wider px-2 py-0.5 rounded border border-gray-200 group-hover:border-black/20 bg-gray-50/50 group-hover:bg-white text-gray-500 group-hover:text-black transition-all">
              {tag}
            </span>
          ))}
        </div>
      )}

      {/* Action Arrow indicator */}
      <span class="hidden md:inline-block text-gray-300 group-hover:text-black group-hover:translate-x-1 transition-all text-sm font-black pl-2 select-none">
        →
      </span>

    </div>

  </div>
</a>
