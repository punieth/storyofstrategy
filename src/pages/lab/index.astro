---
import Layout from "@layouts/Default.astro";
import labData from "../../data/lab-automations.json";

const automations = Object.entries(labData).map(([slug, data]) => ({
  slug,
  ...data
}));

const colors = [
  'bg-[#f5ff85]', // Lime
  'bg-[#00ff88]', // Green
  'bg-[#fef4d1]', // Yellow
];
---

<Layout title="Automation Lab | Story of Strategy" description="A collection of small automations, useful prototypes, and intelligence workflows built to reduce noise.">
  <main class="lab-hub-page page-surface min-h-screen">
    <div class="max-w-6xl mx-auto px-4 py-12">
      
      <!-- Breadcrumb -->
      <nav class="mb-12 flex items-center gap-3 text-[10px] font-black uppercase tracking-widest">
        <a href="/" class="px-3 py-1.5 border-2 border-black bg-white hover:bg-[#f5ff85] transition-colors shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] no-underline text-black">
          Home
        </a>
        <span class="text-xl font-bold rotate-12">/</span>
        <span class="px-3 py-1.5 border-2 border-black bg-black text-white shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] cursor-default">
          The Lab
        </span>
      </nav>

      <header class="mb-20">
        <h1 class="text-6xl md:text-9xl font-black tracking-tighter mb-8 leading-[0.85] uppercase italic">
          The <span class="text-white bg-black px-4 inline-block transform -rotate-2">Automation</span> Lab
        </h1>
        <p class="text-2xl md:text-3xl font-bold leading-tight max-w-3xl opacity-80">
          A collection of autonomous agents and high-leverage workflows built to distill signal from the noise. These systems are designed to scale awareness and capture intelligence in real-time.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {automations.map((item, index) => (
          <a href={`/lab/${item.slug}/`} class="group no-underline block h-full">
            <article class={`h-full p-8 border-4 border-black rounded-3xl ${colors[index % colors.length]} shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all duration-300 hover:translate-x-1 hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] flex flex-col`}>
              <div class="flex items-center justify-between mb-8">
                <div class="flex items-center gap-2 px-3 py-1 bg-white border-2 border-black rounded-full text-[10px] font-black uppercase tracking-widest shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                  <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                  {item.status}
                </div>
                <span class="text-[10px] font-black opacity-40 uppercase tracking-widest">{item.schedule}</span>
              </div>

              <h2 class="text-3xl md:text-4xl font-black tracking-tighter leading-none mb-4 uppercase group-hover:underline decoration-4">
                {item.title}
              </h2>
              
              <p class="text-lg font-bold leading-tight opacity-70 mb-8 flex-grow">
                {item.description}
              </p>

              <div class="mt-auto flex items-center justify-between pt-6 border-t-2 border-black/10">
                <div class="flex -space-x-2">
                  {item.pipeline.slice(0, 3).map((tool: any) => (
                    <div class="w-8 h-8 rounded-full bg-white border-2 border-black flex items-center justify-center overflow-hidden p-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                      {typeof tool === 'string' ? (
                        <span class="text-[8px] font-black">{tool[0]}</span>
                      ) : (
                        <img src={tool.icon} alt={tool.name} class="w-full h-full object-contain" />
                      )}
                    </div>
                  ))}
                  {item.pipeline.length > 3 && (
                     <div class="w-8 h-8 rounded-full bg-black text-white border-2 border-black flex items-center justify-center text-[10px] font-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                       +{item.pipeline.length - 3}
                     </div>
                  )}
                </div>
                <span class="text-xs font-black uppercase tracking-widest group-hover:translate-x-1 transition-transform">Explore ↗</span>
              </div>
            </article>
          </a>
        ))}
      </div>

      <section class="mt-32 pt-20 border-t-4 border-black">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
          <div class="lg:col-span-7">
            <h2 class="text-4xl font-black uppercase tracking-tight mb-8 italic leading-none">The Philosophy</h2>
            <div class="space-y-6 text-xl font-bold leading-tight opacity-80">
              <p>
                Information overload is fundamentally a <span class="bg-[#f5ff85] px-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] border border-black italic font-black">bad design</span> problem. I build these tools to bridge the gap between my brain's finite capacity and the internet's infinite firehose.
              </p>
              <p>
                I design these pipelines as high-performance "noise-cancelers" for data. They utilize infrastructure like watermark deduping (to stop seeing the same thing twice) and quality gates (to make sure the output actually makes sense).
              </p>
              <p>
                The real magic is in the plumbing. I've built "guru-voice" filters to kill the fluff, adversarial loops that double-check the facts, and a synthesis layer that connects dots across 60+ sources so I can stay informed without the existential dread of 500 open tabs.
              </p>
            </div>
          </div>
          <div class="lg:col-span-5 p-8 bg-white border-4 border-black rounded-3xl shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transform rotate-1">
             <h3 class="text-xs font-black uppercase tracking-widest mb-6 text-muted-foreground/60">Current Lab Stack</h3>
             <ul class="space-y-4 font-black uppercase tracking-tighter text-xl">
               <li class="flex items-start gap-3"><span class="w-3 h-3 mt-2 bg-[#00ff88] border-2 border-black rounded-full shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shrink-0"></span> <span>LLM: mimo-v2.5 / MiniMax-M2.7</span></li>
               <li class="flex items-start gap-3"><span class="w-3 h-3 mt-2 bg-[#f5ff85] border-2 border-black rounded-full shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shrink-0"></span> <span>Orchestration: Hermes Agent <small class="block text-[10px] opacity-50 lowercase tracking-normal font-bold">cron + subagent delegation</small></span></li>
               <li class="flex items-start gap-3"><span class="w-3 h-3 mt-2 bg-[#2f62ff] border-2 border-black rounded-full shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shrink-0"></span> <span>Data: SQLite <small class="block text-[10px] opacity-50 lowercase tracking-normal font-bold">watermark dedup + signal storage</small></span></li>
               <li class="flex items-start gap-3"><span class="w-3 h-3 mt-2 bg-[#ff6641] border-2 border-black rounded-full shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shrink-0"></span> <span>Enrichment: Brave Search + Jina Reader</span></li>
               <li class="flex items-start gap-3"><span class="w-3 h-3 mt-2 bg-black border-2 border-black rounded-full shadow-[2px_2px_0px_0px_rgba(0,120,255,0.2)] shrink-0"></span> <span>Delivery: Cloudflare Pages + Discord</span></li>
               <li class="flex items-start gap-3"><span class="w-3 h-3 mt-2 bg-slate-200 border-2 border-black rounded-full shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] shrink-0"></span> <span>Infra: macOS / Python 3.11</span></li>
             </ul>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .lab-hub-page {
    background: 
      radial-gradient(circle at 100% 0%, rgba(36, 87, 255, 0.04), transparent 40%),
      radial-gradient(circle at 0% 100%, rgba(0, 255, 136, 0.04), transparent 40%),
      #f9f8f3;
  }

  h1, h2, h3 {
    backface-visibility: hidden;
    transform: translateZ(0);
  }
</style>
