---
import Layout from "@layouts/Default.astro";
import localLabData from "../../data/lab-automations.json";
import hermesLogo from "../../assets/hermes-logo.webp";

export function getStaticPaths() {
  return [
    { params: { slug: 'newsletter-digest' } },
    { params: { slug: 'reddit-radar' } },
    { params: { slug: 'intelligence-os' } },
  ];
}

const { slug } = Astro.params;

// 1. Attempt to fetch live data from Cloudflare KV
let meta = (localLabData as any)[slug as string];
let labData = meta; // Base metadata
const runtime = (Astro.locals as any).runtime;

if (runtime && runtime.env && runtime.env.LAB_STORE) {
  const kvData = await runtime.env.LAB_STORE.get(`lab:${slug}`);
  if (kvData) {
    const live = JSON.parse(kvData);
    labData = { ...meta, ...live };
  }
}

if (!labData) {
  return Astro.redirect('/404');
}

interface ContentItem {
  title: string;
  source: string;
  summary: string;
  key_insights?: string[];
}

// Hardcoded Pipeline Configurations
const PIPELINES: Record<string, any[]> = {
  'newsletter-digest': [
    { name: "Gmail", icon: "https://api.iconify.design/logos:google-gmail.svg" },
    { name: "Make.com", icon: "https://api.iconify.design/simple-icons:make.svg?color=%238a2be2" },
    { name: "Hermes Agent", icon: hermesLogo.src },
    { name: "MiniMax AI", icon: "https://api.iconify.design/simple-icons:minimax.svg" },
    { name: "Discord", icon: "https://api.iconify.design/logos:discord-icon.svg" }
  ],
  'reddit-radar': [
    { name: "Reddit API", icon: "https://api.iconify.design/logos:reddit-icon.svg" },
    { name: "Hermes Agent", icon: hermesLogo.src },
    { name: "GPT-4o", icon: "https://api.iconify.design/simple-icons:openai.svg" },
    { name: "Discord", icon: "https://api.iconify.design/logos:discord-icon.svg" }
  ],
  'intelligence-os': [
    { name: "RSS Feeds", icon: "https://api.iconify.design/mdi:rss.svg" },
    { name: "Hermes Agent", icon: hermesLogo.src },
    { name: "Claude 3.5", icon: "https://api.iconify.design/logos:claude-icon.svg" },
    { name: "Discord", icon: "https://api.iconify.design/logos:discord-icon.svg" }
  ]
};

const activePipeline = PIPELINES[slug as string] || [];

const FEED_HEADINGS: Record<string, string> = {
  'newsletter-digest': 'Inbox Digest',
  'reddit-radar': 'Signal Radar',
  'intelligence-os': 'Intelligence Feed'
};

const feedHeading = FEED_HEADINGS[slug as string] || 'Intelligence Feed';

const latestRun = labData.latest;
const previousRun = labData.previous;
---

<Layout title={`${labData.title} | Lab`} description={labData.description}>
  <main class="lab-page page-surface min-h-screen">
    <div class="lab-container max-w-6xl mx-auto px-4 py-12">
      
      <!-- Breadcrumb & Header -->
      <nav class="mb-6 flex items-center gap-2 text-xs font-black uppercase tracking-[0.1em] text-muted-foreground/60">
        <a href="/" class="hover:text-foreground transition-colors">Home</a>
        <span class="opacity-30">/</span>
        <span class="text-foreground">The Lab</span>
        <span class="opacity-30">/</span>
        <span class="text-foreground">{labData.title}</span>
      </nav>

      <header class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-6">
           <div class="flex items-center gap-2 px-3 py-1.5 border-2 border-black bg-white rounded-full shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
             <span class="relative flex h-2 w-2">
               <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
               <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
             </span>
             <span class="text-[10px] font-black uppercase tracking-widest">{labData.status}</span>
           </div>
           <div class="flex items-center gap-3 px-3 py-1.5 border-2 border-black/10 bg-black/5 rounded-full">
             <span class="text-[10px] font-black uppercase tracking-widest opacity-60">Schedule: {labData.schedule}</span>
             <span class="w-1 h-1 rounded-full bg-black/20"></span>
             <span class="text-[10px] font-black uppercase tracking-widest opacity-60">Last: {latestRun?.lastRun || 'N/A'}</span>
           </div>
        </div>
        
        <h1 class="text-5xl md:text-8xl font-black tracking-tighter mb-6 leading-[0.8] [backface-visibility:hidden] [transform:translateZ(0)]">{labData.title}</h1>
        <p class="text-xl md:text-2xl text-muted-foreground max-w-3xl leading-tight font-bold opacity-80">
          {labData.description}
        </p>
      </header>

      <!-- Pipeline Visualization (Subtle Horizontal) -->
      <section class="mb-16">
        <div class="py-8 border-y-2 border-black/5 overflow-x-auto no-scrollbar">
          <div class="flex items-center justify-center gap-2 md:gap-12 min-w-max md:min-w-0 mx-auto px-2 md:px-4">
            {activePipeline.map((step: any, i: number) => {
              const name = step.name;
              const icon = step.icon;
              
              return (
                <div class="flex items-center gap-3 md:gap-12">
                  {/* Node */}
                  <div class="flex flex-col items-center gap-2 md:gap-3">
                    <div class={`w-11 h-11 md:w-14 md:h-14 shrink-0 rounded-full border-2 border-black flex items-center justify-center font-black text-[11px] md:text-base shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] md:shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] transition-transform duration-200 hover:-translate-y-1 hover:shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] [backface-visibility:hidden] overflow-hidden ${name === 'Hermes Agent' ? 'bg-[#000] p-1' : 'bg-white p-1.5 md:p-2'}`}>
                      {icon ? (
                        <img 
                          src={icon} 
                          alt={name} 
                          class="w-full h-full object-contain"
                          loading="eager"
                        />
                      ) : (
                        <span>{name[0]}</span>
                      )}
                    </div>
                    <span class="text-[8px] md:text-[9px] font-black uppercase tracking-tighter md:tracking-widest opacity-40 whitespace-nowrap">{name}</span>
                  </div>

                  {/* Arrow */}
                  {i < activePipeline.length - 1 && (
                    <div class="flex flex-col items-center -mt-4 md:-mt-6">
                      <span class="text-black/60 font-black text-xs md:text-3xl">→</span>
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-16">
        <!-- Main Content (The Digest) -->
        <div class="lg:col-span-8">
          <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b-4 border-black pb-4">
             <h2 class="text-3xl md:text-4xl font-black tracking-tighter uppercase italic [backface-visibility:hidden] [transform:translateZ(0)]">{feedHeading}</h2>
             
             <!-- Run Tabs -->
             <div class="flex p-1 bg-black/5 rounded-lg border-2 border-black self-start md:self-auto">
               <button 
                id="tab-latest"
                class="px-4 py-1.5 text-[10px] font-black uppercase tracking-widest rounded-md transition-all bg-black text-white shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
                data-tab="latest"
               >
                Latest
               </button>
               <button 
                id="tab-previous"
                class="px-4 py-1.5 text-[10px] font-black uppercase tracking-widest rounded-md transition-all hover:bg-black/10 disabled:opacity-30 disabled:cursor-not-allowed"
                data-tab="previous"
                disabled={!previousRun}
               >
                Previous
               </button>
             </div>
          </div>

          <div id="content-latest" class="flex flex-col gap-12">
            {latestRun ? (latestRun.content as ContentItem[]).map((item, index) => (
              <article class="relative group p-6 rounded-2xl bg-[#f9f8f3] border-2 border-black/5 shadow-[2px_2px_0px_0px_rgba(0,0,0,0.02)] transition-all duration-300">
                <div class="flex items-center gap-3 mb-4">
                  <span class="w-8 h-1 bg-black"></span>
                  <span class="text-[10px] font-black uppercase tracking-[0.3em] text-white bg-black px-2 py-0.5 rounded">{item.source}</span>
                </div>
                
                <h3 class="text-2xl md:text-4xl font-black tracking-tight mb-4 leading-tight transition-colors duration-300 cursor-default">{item.title}</h3>
                
                <div class="prose-digest max-w-3xl">
                  <div class="text-lg md:text-xl text-muted-foreground/80 leading-relaxed font-medium">
                    {item.summary.split('\n\n').map(p => (
                      <p class="mb-6 last:mb-0">{p}</p>
                    ))}
                  </div>
                </div>
              </article>
            )) : (
              <p class="text-muted-foreground font-bold italic">No data available yet.</p>
            )}
          </div>

          <div id="content-previous" class="flex flex-col gap-12" style="display: none;">
            {previousRun ? (previousRun.content as ContentItem[]).map((item, index) => (
              <article class="relative group p-6 rounded-2xl bg-[#f9f8f3] border-2 border-black/5 shadow-[2px_2px_0px_0px_rgba(0,0,0,0.02)] transition-all duration-300">
                <div class="flex items-center gap-3 mb-4">
                  <span class="w-8 h-1 bg-black/20"></span>
                  <span class="text-[10px] font-black uppercase tracking-[0.3em] text-muted-foreground bg-black/5 px-2 py-0.5 rounded">{item.source}</span>
                </div>
                
                <h3 class="text-2xl md:text-4xl font-black tracking-tight mb-4 leading-tight opacity-60">{item.title}</h3>
                
                <div class="prose-digest max-w-3xl">
                  <div class="text-lg md:text-xl text-muted-foreground/60 leading-relaxed font-medium">
                    {item.summary.split('\n\n').map(p => (
                      <p class="mb-6 last:mb-0">{p}</p>
                    ))}
                  </div>
                </div>
              </article>
            )) : null}
          </div>
        </div>

        <!-- Sidebar Meta -->
        <aside class="lg:col-span-4">
          <div class="sticky top-12">
            <div id="meta-card" class="p-6 border-2 border-black bg-white rounded-2xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
              <h3 class="text-xs font-black uppercase tracking-widest mb-5 border-b-2 border-black/5 pb-4">Execution Metadata</h3>
              <div class="space-y-4">
                <div class="group">
                  <span class="text-[10px] font-black text-muted-foreground uppercase tracking-widest block mb-1">Items Processed</span>
                  <span id="meta-processed" class="text-3xl font-black tracking-tighter">{latestRun?.stats.processed || 0}</span>
                </div>
                <div class="group">
                  <span class="text-[10px] font-black text-muted-foreground uppercase tracking-widest block mb-1">Context Window</span>
                  <span id="meta-tokens" class="text-3xl font-black tracking-tighter">{latestRun?.stats.tokens || 0} <small class="text-sm opacity-40">tokens</small></span>
                </div>
                <div class="group">
                  <span class="text-[10px] font-black text-muted-foreground uppercase tracking-widest block mb-1">Model Architecture</span>
                  <span id="meta-model" class="text-lg font-black block mt-2 px-3 py-2 border-2 border-black bg-primary/5 rounded-xl">{latestRun?.stats.model || 'N/A'}</span>
                </div>
              </div>

              <div class="mt-6 pt-4 border-t-2 border-black/5">
                <p class="text-[10px] font-black uppercase tracking-widest mb-3 opacity-40">Current Pipeline Status</p>
                <div class="flex items-center gap-2 text-xs font-bold text-green-600">
                  <span class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"></span>
                  Systems Operational
                </div>
              </div>
            </div>

            <div class="mt-8 p-8 border-2 border-black bg-primary text-primary-foreground rounded-2xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
               <h3 class="text-xl font-black tracking-tight mb-4 leading-tight">This is an automated workflow.</h3>
               <p class="text-base font-bold opacity-80 leading-relaxed mb-10">
                 The summaries above are generated daily by the Hermes Agent. I use this to maintain high-signal awareness without the inbox fatigue.
               </p>
               <button class="w-full py-4 bg-black text-white font-black uppercase tracking-[0.2em] text-[11px] border-2 border-black hover:translate-x-1 hover:-translate-y-1 transition-all shadow-[4px_4px_0px_0px_rgba(255,255,255,1)]">
                 Build one for your team
               </button>
            </div>
          </div>
        </aside>
      </div>

    </div>
  </main>
</Layout>

<script is:inline define:vars={{ latestRun, previousRun }}>
  function initTabs() {
    const tabLatest = document.getElementById('tab-latest');
    const tabPrevious = document.getElementById('tab-previous');
    const contentLatest = document.getElementById('content-latest');
    const contentPrevious = document.getElementById('content-previous');
    
    const metaProcessed = document.getElementById('meta-processed');
    const metaTokens = document.getElementById('meta-tokens');
    const metaModel = document.getElementById('meta-model');

    if (!tabLatest || !tabPrevious || !contentLatest || !contentPrevious) return;

    function updateSidebar(run) {
      if (!run || !metaProcessed || !metaTokens || !metaModel) return;
      metaProcessed.textContent = run.stats.processed;
      metaTokens.innerHTML = `${run.stats.tokens} <small class="text-sm opacity-40">tokens</small>`;
      metaModel.textContent = run.stats.model;
    }

    function switchTab(type) {
      const isLatest = type === 'latest';
      
      // Update Tab Styles
      tabLatest.classList.toggle('bg-black', isLatest);
      tabLatest.classList.toggle('text-white', isLatest);
      tabLatest.classList.toggle('shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]', isLatest);
      
      tabPrevious.classList.toggle('bg-black', !isLatest);
      tabPrevious.classList.toggle('text-white', !isLatest);
      tabPrevious.classList.toggle('shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]', !isLatest);
      
      // Update Content Visibility
      contentLatest.style.display = isLatest ? 'flex' : 'none';
      contentPrevious.style.display = isLatest ? 'none' : 'flex';
      
      // Update Meta
      updateSidebar(isLatest ? latestRun : previousRun);
    }

    tabLatest.addEventListener('click', () => switchTab('latest'));
    tabPrevious.addEventListener('click', () => {
      if (!tabPrevious.disabled) switchTab('previous');
    });

    // Force initial state
    switchTab('latest');
  }

  // Initialize on first load
  initTabs();

  // Re-initialize after Astro View Transitions swap the page content
  document.addEventListener('astro:after-swap', initTabs);
</script>

<style>
  .lab-page {
    background: 
      radial-gradient(circle at 100% 0%, rgba(36, 87, 255, 0.03), transparent 40%),
      radial-gradient(circle at 0% 100%, rgba(0, 255, 136, 0.03), transparent 40%),
      #fbfaf6;
  }

  .prose-digest p {
    max-width: 65ch;
  }

  /* Custom scrollbar for the long feed */
  ::-webkit-scrollbar {
    width: 12px;
  }
  ::-webkit-scrollbar-track {
    background: #fbfaf6;
  }
  ::-webkit-scrollbar-thumb {
    background: #000;
    border: 3px solid #fbfaf6;
    border-radius: 10px;
  }
</style>
