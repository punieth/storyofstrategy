---
import Layout from "../../layouts/Prototype.astro";
---

<Layout
  title="Urban Company Prototype"
  description="Interactive prototype of Urban Company remote home service orchestration"
>
  <!-- Loader Overlay -->
  <div id="loader" class="loader-container">
    <div class="loader-spinner loader-spinner--urban"></div>
    <p class="loader-text">Launching Home Flow App...</p>
  </div>

  <iframe
    src="https://orchestrate-home-flow.lovable.app/"
    title="Urban Company Interactive Flow"
    class="fullscreen-iframe"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
  ></iframe>
</Layout>

<script>
  // Wait for the iframe to load, then fade out the loader overlay
  const iframe = document.querySelector('.fullscreen-iframe') as HTMLIFrameElement;
  const loader = document.getElementById('loader');

  if (iframe && loader) {
    iframe.addEventListener('load', () => {
      loader.style.opacity = '0';
      loader.style.transition = 'opacity 0.4s ease';
      setTimeout(() => {
        loader.style.display = 'none';
      }, 400);
    });
  }
</script>

<style>
  .fullscreen-iframe {
    width: 100%;
    height: 100%;
    border: none;
    margin: 0;
    padding: 0;
    display: block;
    overflow: hidden;
  }
</style>
