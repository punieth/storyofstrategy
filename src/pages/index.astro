---
import Layout from "@layouts/Default.astro";
import BrutalCard from "@components/layout/Brutalcard.astro";
---

<Layout
  title="Punith R"
  description="Software engineer. 8 years shipping software. Now exploring product ideas, automations, and whatever I find interesting."
>
  <main class="page-surface flex-grow border-b-[12px] border-frame">
    <h1 class="sr-only">Punith R — Software Engineer exploring Product</h1>

    {/* ── HERO — full width, big statement ── */}
    <div class="px-5 pt-8 pb-6 md:px-10 md:pt-12 md:pb-8">
      <div class="mx-auto w-full max-w-6xl">
        <section id="hero">
          <BrutalCard tone="hero">
            <div class="flex flex-col gap-5 md:gap-6">
              <p
                class="brutal-headline-strong text-3xl leading-[1.05] md:text-5xl lg:text-6xl"
              >
                I'm Punith.
              </p>
              <p class="brutal-headline text-lg leading-tight md:text-2xl lg:text-3xl">
                Software engineer for 8 years.
              </p>
              
              <p class="brutal-body text-base md:text-lg max-w-2xl">
                Lately I've been building AI workflows, thinking about products,
                and working on a few side projects.
              </p>
              <a href="#stuff" class="btn btn--sun w-fit"
                >See what I'm up to ↓</a
              >
            </div>
          </BrutalCard>
        </section>
      </div>
    </div>

    {/* ── BENTO GRID ── */}
    <div class="px-5 pb-8 md:px-10 md:pb-10">
      <div class="mx-auto w-full max-w-6xl">
        <section id="stuff">
          <h2 class="brutal-label text-xs md:text-sm tracking-[0.24em] mb-6">
            Things I've been up to
          </h2>

          <div class="bento-grid">
            <div class="bento-cell bento-cell--warm bento-span-2 animate-in">
              <span class="bento-label">Automations</span>
              <h3 class="bento-title">Things that run while I sleep</h3>
              <div class="bento-flows">
                <p class="bento-flow">
                  Reddit r/productmanagement
                  <span class="bento-flow-arrow">→</span>
                  AI summary
                  <span class="bento-flow-arrow">→</span>
                  LinkedIn post, daily
                </p>
                <p class="bento-flow">
                  Gmail newsletters
                  <span class="bento-flow-arrow">→</span>
                  AI digest
                  <span class="bento-flow-arrow">→</span>
                  Discord channel
                </p>
              </div>
              <span class="bento-tech">n8n · ai · runs daily</span>
            </div>

            <div class="bento-cell bento-cell--cool animate-in">
              <span class="bento-label">Product exploration</span>

<h3 class="bento-title">
Remote Home Management
</h3>

<p class="bento-desc">
How do you manage a home from another country? An idea using service
providers, messaging, and automation.
</p>
              <span class="bento-tech">n8n · webhooks · mobile</span>
            </div>

            <div class="bento-cell bento-cell--dark animate-in">
              <span class="bento-label">Meta</span>
              <h3 class="bento-title bento-title--light">This website</h3>
              <p class="bento-desc bento-desc--light">
                The thing you're looking at. Custom neo-brutalist design system,
                visitor tracking, interactive terminal (<kbd class="bento-kbd"
                  >Ctrl+K</kbd
                >).
              </p>
              <span class="bento-tech bento-tech--light"
                >Astro · UnoCSS · Cloudflare</span
              >
            </div>

            <div class="bento-cell bento-cell--muted bento-span-2 animate-in">
              <span class="bento-label">Ideas</span>
              <h3 class="bento-title">Things I haven't built yet</h3>
              <div class="bento-ideas">
                <div class="bento-idea">
                  <strong>RoastMyLinkedIn</strong>
                  <span
                    >AI roasts your LinkedIn profile. Fun, shareable, one-page
                    app.</span
                  >
                </div>
                <div class="bento-idea">
                  <strong>Philosophy × Building</strong>
                  <span
                    >Curated wisdom for people who think too much and build too
                    little.</span
                  >
                </div>
                <div class="bento-idea bento-idea--faded">
                  <strong>+ more</strong>
                  <span>Half-baked things sitting in my notes app.</span>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>

    {/* ── PULL QUOTE ── */}
    <div class="px-5 py-6 md:px-10 md:py-8">
      <section
        class="pull-quote-section animate-in"
        aria-label="Personal statement"
      >
        <p class="pull-quote">
          I don't have it all figured out.<br />
          But I'm
          <span class="pull-quote-highlight">building</span> while I figure it out.
        </p>
      </section>
    </div>

    {/* ── THE LAB ── */}
    <div class="px-5 pb-8 md:px-10 md:pb-10">
      <div class="mx-auto w-full max-w-4xl">
        <section class="lab-cta animate-in">
          <div class="lab-cta-content">
            <h2
              class="brutal-headline-strong text-xl md:text-3xl leading-tight"
            >
            Product notes
            </h2>
            <p class="brutal-body text-sm md:text-base mt-2 max-w-lg">
              PRDs, product ideas, and things I'm trying to understand.
            </p>
          </div>
          <a href="/blog/" class="btn btn--sun">Enter The Lab →</a>
        </section>
      </div>
    </div>

    {/* ── BACKSTORY ── */}
    <div class="px-5 pb-10 md:px-10 md:pb-14">
      <div class="mx-auto w-full max-w-4xl">
        <section id="backstory" class="backstory-section animate-in">
          <h2 class="brutal-title text-lg md:text-2xl mb-4">The Backstory</h2>
          <p class="brutal-body text-base md:text-lg">
            I've spent the last 8 years building software, from trading platforms to UI systems used across engineering teams.
          </p>
          <p class="brutal-body text-base md:text-lg mt-3">
            After several years in the US, I moved back to India. I'm interested
            in AI, products, and the kinds of problems that affect millions of
            people here.
          </p>
        </section>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Scroll-triggered fade-in animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
  );

  document.querySelectorAll(".animate-in").forEach((el) => {
    observer.observe(el);
  });
</script>
